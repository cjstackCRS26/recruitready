  const lvl = d.level;

  doc.setFont('helvetica', 'bold');
  doc.setFontSize(7);
  doc.setTextColor(...GRAY);
  doc.text('RECRUIT READY LEVEL', badgeX, scoreY + 8);

  // Level pill
  const lvlColor = {
    'Recruit Ready':    [29, 131, 72],
    'On the Path':      [26, 82, 118],
    'Developing':       [120, 66, 18],
    'Awareness Stage':  [108, 52, 131],
