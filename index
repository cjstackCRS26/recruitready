<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recruit Ready Institutional Audit — CRS</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1B2A4A;
    --navy-deep: #0F1D33;
    --gold: #C9A84C;
    --gold-light: #F0DFA0;
    --gold-pale: #FBF5E4;
    --green: #2E8B57;
    --green-pale: #E8F5EE;
    --white: #FFFFFF;
    --off-white: #F7F8FC;
    --mid: #E4E8F2;
    --gray: #6B7A94;
    --text: #1a2340;

    --s-color: #1B4F72;
    --m-color: #1D6A4E;
    --a-color: #7B341E;
    --r-color: #4A235A;
    --t-color: #1A3A4A;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--off-white);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .header {
    background: var(--navy-deep);
    padding: 28px 24px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.2);
  }
  .header::after {
    content: '';
    position: absolute;
    bottom: -40px; left: -40px;
    width: 140px; height: 140px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.12);
  }
  .header-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3.5px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .header-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 7vw, 36px);
    font-weight: 900;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 6px;
  }
  .header-title span { color: var(--gold); }
  .header-subtitle {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    font-weight: 300;
    margin-top: 8px;
  }
  .header-bar {
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--green), var(--gold));
    margin-top: 22px;
  }

  /* ── INTRO ── */
  .intro {
    background: var(--white);
    padding: 20px 20px 18px;
    border-bottom: 1px solid var(--mid);
  }
  .intro p {
    font-size: 13.5px;
    color: var(--gray);
    line-height: 1.6;
    font-style: italic;
  }

  /* ── SCHOOL INFO ── */
  .school-section {
    background: var(--white);
    padding: 22px 20px;
    border-bottom: 4px solid var(--mid);
  }
  .school-section h3 {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .field-row {
    margin-bottom: 14px;
  }
  .field-row label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .field-row input, .field-row select {
    width: 100%;
    border: 1.5px solid var(--mid);
    border-radius: 6px;
    padding: 10px 13px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: var(--off-white);
    outline: none;
    transition: border-color 0.2s;
  }
  .field-row input:focus, .field-row select:focus {
    border-color: var(--gold);
    background: var(--white);
  }
  .field-hint {
    font-size: 11px;
    color: var(--gray);
    margin-top: 5px;
    font-style: italic;
  }

  /* ── SCALE KEY ── */
  .scale-key {
    background: var(--gold-pale);
    border-left: 3px solid var(--gold);
    padding: 14px 16px;
    margin: 0 0 0 0;
  }
  .scale-key-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .scale-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .scale-pill {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--navy);
  }
  .scale-pill .num {
    background: var(--navy);
    color: var(--white);
    width: 18px; height: 18px;
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700;
    flex-shrink: 0;
  }

  /* ── DIMENSION SECTIONS ── */
  .dimension {
    margin-bottom: 0;
    border-bottom: 4px solid var(--mid);
  }
  .dim-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px 14px;
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--white);
    border-bottom: 1px solid var(--mid);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .dim-letter {
    width: 44px; height: 44px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 26px; font-weight: 900;
    color: var(--white);
    flex-shrink: 0;
  }
  .dim-info { flex: 1; }
  .dim-word {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.1;
  }
  .dim-tagline {
    font-size: 11.5px;
    color: var(--gray);
    font-style: italic;
    margin-top: 2px;
    line-height: 1.4;
  }
  .dim-score-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--white);
    background: var(--navy);
    padding: 4px 9px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── QUESTION ── */
  .question {
    padding: 16px 20px 14px;
    background: var(--white);
    border-bottom: 1px solid var(--mid);
    transition: background 0.15s;
  }
  .question:last-of-type { border-bottom: none; }
  .question.answered { background: var(--off-white); }
  .question-row {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .q-num {
    width: 22px; height: 22px;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700;
    color: var(--white);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .q-text {
    flex: 1;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text);
    font-weight: 400;
  }
  .rating-row {
    display: flex;
    gap: 6px;
    margin-top: 12px;
    justify-content: flex-end;
  }
  .rating-btn {
    width: 42px; height: 42px;
    border-radius: 8px;
    border: 2px solid var(--mid);
    background: var(--off-white);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--gray);
    cursor: pointer;
    transition: all 0.15s;
    display: flex; align-items: center; justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }
  .rating-btn:hover { border-color: var(--gold); color: var(--navy); }
  .rating-btn.selected {
    color: var(--white);
    border-color: transparent;
    transform: scale(1.08);
    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
  }

  /* ── PROGRESS BAR ── */
  .progress-bar-wrap {
    background: var(--white);
    padding: 14px 20px;
    border-bottom: 1px solid var(--mid);
    position: sticky;
    bottom: 0;
    z-index: 20;
    box-shadow: 0 -3px 12px rgba(0,0,0,0.07);
  }
  .progress-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
  }
  .progress-label { font-size: 11px; font-weight: 600; color: var(--gray); letter-spacing: 0.5px; }
  .progress-count { font-size: 11px; font-weight: 700; color: var(--navy); }
  .progress-track {
    height: 6px;
    background: var(--mid);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--navy), var(--gold));
    transition: width 0.4s ease;
    width: 0%;
  }

  /* ── SUBMIT ── */
  .submit-section {
    padding: 28px 20px 40px;
    background: var(--white);
  }
  .submit-note {
    font-size: 12px;
    color: var(--gray);
    text-align: center;
    margin-bottom: 16px;
    font-style: italic;
  }
  .submit-btn {
    width: 100%;
    background: var(--navy);
    color: var(--white);
    border: none;
    border-radius: 10px;
    padding: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .submit-btn:hover { background: var(--navy-deep); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(27,42,74,0.3); }
  .submit-btn:disabled { background: var(--mid); color: var(--gray); cursor: not-allowed; transform: none; box-shadow: none; }
  .submit-note-warning {
    font-size: 11.5px;
    color: #c0392b;
    text-align: center;
    margin-top: 10px;
    display: none;
  }

  /* ── RESULTS ── */
  #results-screen {
    display: none;
    min-height: 100vh;
    background: var(--navy-deep);
  }
  .results-header {
    padding: 32px 24px 24px;
    text-align: center;
    position: relative;
  }
  .results-header::before {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 180px; height: 180px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.15);
  }
  .results-eyebrow {
    font-size: 10px; font-weight: 600; letter-spacing: 3px;
    color: var(--gold); text-transform: uppercase; margin-bottom: 10px;
  }
  .results-school-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }
  .results-name {
    font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 24px;
  }
  .score-circle {
    width: 140px; height: 140px;
    border-radius: 50%;
    border: 4px solid var(--gold);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    margin: 0 auto 10px;
    position: relative;
    background: rgba(201,168,76,0.07);
  }
  .score-number {
    font-family: 'Playfair Display', serif;
    font-size: 52px; font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }
  .score-denom {
    font-size: 13px; color: rgba(255,255,255,0.4); font-weight: 300;
  }
  .score-label {
    font-size: 11px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(255,255,255,0.6);
    margin-bottom: 6px;
  }
  .level-badge {
    display: inline-block;
    padding: 10px 20px;
    border-radius: 99px;
    font-size: 14px; font-weight: 700;
    letter-spacing: 0.5px;
    margin-top: 12px;
    margin-bottom: 4px;
  }
  .level-description {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    text-align: center;
    line-height: 1.6;
    padding: 0 10px;
    margin-bottom: 28px;
    font-style: italic;
  }

  /* dimension breakdown */
  .breakdown {
    background: rgba(255,255,255,0.04);
    margin: 0 16px 24px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .breakdown-title {
    font-size: 10px; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: var(--gold);
    padding: 14px 16px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .breakdown-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .breakdown-row:last-child { border-bottom: none; }
  .br-letter {
    width: 30px; height: 30px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 16px; font-weight: 900;
    color: var(--white);
    flex-shrink: 0;
  }
  .br-word { font-size: 13px; font-weight: 500; color: var(--white); flex: 1; }
  .br-bar-wrap { width: 80px; height: 6px; background: rgba(255,255,255,0.1); border-radius: 99px; overflow: hidden; }
  .br-bar { height: 100%; border-radius: 99px; transition: width 0.8s ease; }
  .br-score { font-size: 13px; font-weight: 700; color: var(--gold); width: 40px; text-align: right; }

  /* next steps */
  .next-steps {
    margin: 0 16px 32px;
  }
  .next-steps-title {
    font-size: 10px; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 14px;
  }
  .next-step-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 10px;
  }
  .ns-head { font-size: 13px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .ns-body { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.5; }

  .results-footer {
    padding: 24px 20px 40px;
    text-align: center;
  }
  .results-footer p {
    font-size: 12px; color: rgba(255,255,255,0.3); font-style: italic; line-height: 1.6;
  }
  .results-footer strong { color: var(--gold); font-style: normal; }

  .results-bar {
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--green), var(--gold));
    margin-bottom: 30px;
  }

  /* ── DOWNLOAD BUTTON ── */
  .download-section {
    padding: 0 16px 24px;
  }
  .download-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--gold), #b8860b);
    color: var(--navy-deep);
    border: none;
    border-radius: 10px;
    padding: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    -webkit-tap-highlight-color: transparent;
    margin-bottom: 10px;
  }
  .download-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,168,76,0.4); }
  .download-btn:active { transform: translateY(0); }
  .download-btn svg { flex-shrink: 0; }
  .download-note {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    text-align: center;
    font-style: italic;
  }

  /* animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.5s ease forwards; }
  @keyframes countUp {
    from { opacity: 0; transform: scale(0.6); }
    to   { opacity: 1; transform: scale(1); }
  }
  .count-up { animation: countUp 0.6s cubic-bezier(0.34,1.56,0.64,1) forwards; }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body>

<!-- ═══════════════════════════════════════════
     AUDIT FORM
═══════════════════════════════════════════ -->
<div id="form-screen">

  <div class="header">
    <div class="header-eyebrow">College Recruiting Standard</div>
    <div class="header-title">Recruit Ready<br><span>Institutional Audit</span></div>
    <div class="header-subtitle">SMART Recruit Framework Self-Assessment</div>
    <div class="header-bar"></div>
  </div>

  <div class="intro">
    <p>Rate your school honestly on each statement. This is a tool for growth — not judgment. Your score will reveal your school's Recruit Ready level instantly.</p>
  </div>

  <!-- School Info -->
  <div class="school-section">
    <h3>Your Information</h3>
    <div class="field-row">
      <label>Your Name</label>
      <input type="text" id="respondent-name" placeholder="First and Last Name" autocomplete="name">
    </div>
    <div class="field-row">
      <label>School Name</label>
      <input type="text" id="school-name" placeholder="School or Institution" autocomplete="organization">
    </div>
    <div class="field-row">
      <label>Your Role</label>
      <select id="respondent-role">
        <option value="">Select your role…</option>
        <option>Athletic Director</option>
        <option>Assistant Athletic Director</option>
        <option>Head Coach</option>
        <option>School Counselor</option>
        <option>Academic Advisor</option>
        <option>Administrator / Principal</option>
        <option>Other</option>
      </select>
    </div>
    <div class="field-row">
      <label>Email Address</label>
      <input type="email" id="respondent-email" placeholder="your@email.com" autocomplete="email">
      <div class="field-hint">We'll use this to share resources based on your results</div>
    </div>
  </div>

  <!-- Scale Key -->
  <div class="scale-key">
    <div class="scale-key-title">Rating Scale</div>
    <div class="scale-pills">
      <div class="scale-pill"><div class="num">1</div> Not in place</div>
      <div class="scale-pill"><div class="num">2</div> Rarely</div>
      <div class="scale-pill"><div class="num">3</div> Sometimes</div>
      <div class="scale-pill"><div class="num">4</div> Consistently</div>
      <div class="scale-pill"><div class="num">5</div> Fully embedded</div>
    </div>
  </div>

  <!-- Dimensions injected by JS -->
  <div id="dimensions-container"></div>

  <!-- Sticky Progress -->
  <div class="progress-bar-wrap">
    <div class="progress-top">
      <span class="progress-label">Questions Answered</span>
      <span class="progress-count" id="progress-count">0 / 20</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
  </div>

  <!-- Submit -->
  <div class="submit-section">
    <p class="submit-note">Answer all 20 questions to see your Recruit Ready score</p>
    <button class="submit-btn" id="submit-btn" disabled onclick="showResults()">
      See My Recruit Ready Score →
    </button>
    <p class="submit-note-warning" id="warn-msg">Please answer all 20 questions before submitting.</p>
  </div>

</div><!-- /form-screen -->


<!-- ═══════════════════════════════════════════
     RESULTS SCREEN
═══════════════════════════════════════════ -->
<div id="results-screen">
  <div class="results-bar"></div>
  <div class="results-header">
    <div class="results-eyebrow">Your Recruit Ready Assessment</div>
    <div class="results-school-name" id="res-school">—</div>
    <div class="results-name" id="res-name">—</div>
    <p class="score-label">Total Score</p>
    <div class="score-circle count-up" style="display:none" id="score-circle">
      <div class="score-number" id="res-score">—</div>
      <div class="score-denom">out of 100</div>
    </div>
    <div class="level-badge" id="res-level-badge">—</div>
    <div class="level-description" id="res-level-desc">—</div>
  </div>

  <div class="breakdown fade-up" id="breakdown-wrap" style="opacity:0">
    <div class="breakdown-title">Score by Dimension</div>
    <div id="breakdown-rows"></div>
  </div>

  <div class="next-steps fade-up" id="next-steps-wrap" style="opacity:0">
    <div class="next-steps-title">Your Next Step</div>
    <div id="next-step-card"></div>
  </div>

  <div class="download-section fade-up" id="download-section-wrap" style="opacity:0">
    <button class="download-btn" onclick="downloadReport()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download My Audit Report (PDF)
    </button>
    <p class="download-note">Share with your principal, superintendent, or leadership team</p>
  </div>

  <div class="results-footer">
    <p><strong>College Recruiting Standard</strong><br>Bringing College Recruiting Education<br>into the Academic Arena</p>
  </div>
</div><!-- /results-screen -->


<script>
// ── DATA ────────────────────────────────────────
const DIMENSIONS = [
  {
    id: 'S', word: 'Systemic', color: '#1B4F72',
    tagline: 'Do you have a system in place to support and guide students?',
    questions: [
      'Our school has a clearly defined, written process for supporting student-athletes in the college recruiting journey.',
      'Recruiting guidance is integrated into our existing academic advising and counseling structure.',
      'Students can access consistent, standardized recruiting resources regardless of which coach or counselor they work with.',
      'Our school has a designated staff member or role responsible for overseeing recruiting education and support.',
    ]
  },
  {
    id: 'M', word: 'Measurable', color: '#1D6A4E',
    tagline: 'Are you measuring the right data and identifying students early?',
    questions: [
      'We track and monitor which students have expressed interest in playing college sports.',
      'We identify student-athletes with college athletic potential by their freshman or sophomore year.',
      'We collect data on recruiting outcomes — offers, commitments, scholarship amounts — for our graduates.',
