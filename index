// ── SCORES STATE ─────────────────────────────────
const scores = {}; // key: "S_0", "M_2", etc.

// ── BUILD FORM ───────────────────────────────────
function buildForm() {
  const container = document.getElementById('dimensions-container');
  DIMENSIONS.forEach(dim => {
    const sec = document.createElement('div');
    sec.className = 'dimension';

    // Header
    const hdr = document.createElement('div');
    hdr.className = 'dim-header';
    hdr.innerHTML = `
      <div class="dim-letter" style="background:${dim.color}">${dim.id}</div>
      <div class="dim-info">
        <div class="dim-word" style="color:${dim.color}">${dim.word}</div>
        <div class="dim-tagline">${dim.tagline}</div>
      </div>
      <div class="dim-score-badge" id="badge-${dim.id}">0 / 20</div>
    `;
    sec.appendChild(hdr);

    // Questions
    dim.questions.forEach((q, qi) => {
      const key = `${dim.id}_${qi}`;
      const qDiv = document.createElement('div');
      qDiv.className = 'question';
      qDiv.id = `q-${key}`;

      const globalNum = DIMENSIONS.indexOf(dim) * 4 + qi + 1;

      let ratingHtml = '<div class="rating-row">';
      for (let n = 1; n <= 5; n++) {
        ratingHtml += `<button class="rating-btn" data-key="${key}" data-val="${n}" onclick="rate('${key}', ${n}, this)" aria-label="Rate ${n}">${n}</button>`;
      }
      ratingHtml += '</div>';

      qDiv.innerHTML = `
        <div class="question-row">
          <div class="q-num" style="background:${dim.color}">${globalNum}</div>
          <div class="q-text">${q}</div>
        </div>
        ${ratingHtml}
      `;
      sec.appendChild(qDiv);
    });

    container.appendChild(sec);
  });
}

// ── RATE ────────────────────────────────────────
function rate(key, val, btn) {
  scores[key] = val;

  // Update button states
  const row = btn.closest('.rating-row');
  const dimId = key.split('_')[0];
  const dim = DIMENSIONS.find(d => d.id === dimId);

  row.querySelectorAll('.rating-btn').forEach(b => {
    b.classList.remove('selected');
    b.style.background = '';
    b.style.color = '';
  });
  btn.classList.add('selected');
  btn.style.background = dim.color;

  // Mark question answered
  document.getElementById(`q-${key}`).classList.add('answered');

  // Update dim badge
  updateDimBadge(dimId);

  // Update progress
  updateProgress();
}

function updateDimBadge(dimId) {
  const dim = DIMENSIONS.find(d => d.id === dimId);
  let total = 0;
  dim.questions.forEach((_, qi) => {
    total += scores[`${dimId}_${qi}`] || 0;
  });
  const badge = document.getElementById(`badge-${dimId}`);
  badge.textContent = `${total} / 20`;
  badge.style.background = total >= 16 ? dim.color : '#1B2A4A';
}

function updateProgress() {
  const answered = Object.keys(scores).length;
  document.getElementById('progress-count').textContent = `${answered} / 20`;
  document.getElementById('progress-fill').style.width = `${(answered / 20) * 100}%`;

  const btn = document.getElementById('submit-btn');
  btn.disabled = answered < 20;
}

// ── RESULTS ─────────────────────────────────────
function showResults() {
  const answered = Object.keys(scores).length;
  if (answered < 20) {
    document.getElementById('warn-msg').style.display = 'block';
    return;
  }

  // Calculate totals
  let grandTotal = 0;
  const dimTotals = {};
  DIMENSIONS.forEach(dim => {
    let t = 0;
    dim.questions.forEach((_, qi) => { t += scores[`${dim.id}_${qi}`] || 0; });
    dimTotals[dim.id] = t;
    grandTotal += t;
  });

  // Find level
  const level = LEVELS.find(l => grandTotal >= l.min && grandTotal <= l.max);

  // School info
  const school = document.getElementById('school-name').value.trim() || 'Your School';
  const name   = document.getElementById('respondent-name').value.trim() || '';
  const role   = document.getElementById('respondent-role').value || '';
  const email  = document.getElementById('respondent-email').value.trim() || '';

  // Populate results
  // --- DATA COLLECTION ---
  const auditData = {
    name: name,
    school: school,
    role: role,
    email: email,
    totalScore: grandTotal,
    level: level.label,
    s_score: dimTotals['S'],
    m_score: dimTotals['M'],
    a_score: dimTotals['A'],
    r_score: dimTotals['R'],
    t_score: dimTotals['T']
  };

  fetch('https://script.google.com/macros/s/AKfycbz87L-lxiMhZKXSf_2b9eek-unFlqBH_gUAVVRIxn4Q2v_OB5kE6JxoavIP2mHuwOJo/exec', {
    method: 'POST',
    mode: 'no-cors',
    cache: 'no-cache',
    body: JSON.stringify(auditData)
  });
  // --- END DATA COLLECTION ---

  document.getElementById('res-school').textContent = school;
  document.getElementById('res-name').textContent = name + (role ? ` · ${role}` : '') + (email ? ` · ${email}` : '');
  document.getElementById('res-score').textContent = grandTotal;

  const circle = document.getElementById('score-circle');
  circle.style.display = 'flex';
  circle.style.borderColor = level.bg;

  const badge = document.getElementById('res-level-badge');
  badge.textContent = level.label;
  badge.style.background = level.bg;
  badge.style.color = level.text;

  document.getElementById('res-level-desc').textContent = level.desc;

  // Breakdown
  const bRows = document.getElementById('breakdown-rows');
  bRows.innerHTML = '';
  DIMENSIONS.forEach(dim => {
    const t = dimTotals[dim.id];
    const pct = (t / 20) * 100;
    const row = document.createElement('div');
    row.className = 'breakdown-row';
    row.innerHTML = `
      <div class="br-letter" style="background:${dim.color}">${dim.id}</div>
      <div class="br-word">${dim.word}</div>
      <div class="br-bar-wrap"><div class="br-bar" style="width:0%;background:${dim.color}" data-pct="${pct}"></div></div>
      <div class="br-score">${t}/20</div>
    `;
    bRows.appendChild(row);
  });

  // Next step
  document.getElementById('next-step-card').innerHTML = `
    <div class="next-step-card">
      <div class="ns-head">${level.next.head}</div>
      <div class="ns-body">${level.next.body}</div>
    </div>
  `;

  // Store globally for PDF generation
  window._reportData = { name, school, role, email, grandTotal, level, dimTotals };

  // Switch screens
  document.getElementById('form-screen').style.display = 'none';
  document.getElementById('results-screen').style.display = 'block';
  window.scrollTo(0, 0);

  // Animate bars with delay
  setTimeout(() => {
    document.getElementById('breakdown-wrap').style.opacity = '1';
    document.getElementById('next-steps-wrap').style.opacity = '1';
    document.getElementById('download-section-wrap').style.opacity = '1';
    document.querySelectorAll('.br-bar').forEach(bar => {
      bar.style.width = bar.dataset.pct + '%';
    });
  }, 300);
}

